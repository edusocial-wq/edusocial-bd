# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/edusocial?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get API key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxx"
EMAIL_FROM="EduSocial BD <noreply@yourdomain.com>"

# ─── Cloudflare R2 (file storage) ────────────────────────────────────────────
# Create bucket at https://dash.cloudflare.com
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="edusocial-files"
R2_PUBLIC_URL="https://pub-XXXX.r2.dev"

# ─── Cloudflare Stream (video) ────────────────────────────────────────────────
CF_STREAM_TOKEN="your-cloudflare-api-token"
CF_STREAM_ACCOUNT_ID="your-cloudflare-account-id"

# ─── SSLCommerz (Bangladesh payments) ────────────────────────────────────────
# Sandbox: https://developer.sslcommerz.com
SSLCOMMERZ_STORE_ID="your-store-id"
SSLCOMMERZ_STORE_PASSWORD="your-store-password"
SSLCOMMERZ_SANDBOX="true"

# ─── Claude API (AI Studio - Poem Writer) ────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxx"

# ─── Stability AI (AI Art) ───────────────────────────────────────────────────
STABILITY_API_KEY="sk-xxxxxxxxxx"

# ─── Remove.bg (Photo Editing) ───────────────────────────────────────────────
REMOVEBG_API_KEY="your-removebg-key"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
